# ===========================================
# BikeFit Pro - Arquivos Ignorados pelo Git
# ===========================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.eggs/
*.egg-info/
*.egg

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment
.env
.env.local
*.local

# Build
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db

# Database
*.db
*.sqlite3

# Logs
*.log
logs/

# Data (arquivos grandes)
data/sessoes/*
data/exports/*
!data/sessoes/.gitkeep
!data/exports/.gitkeep

# Models (arquivos grandes)
*.pt
*.pth
*.onnx
*.tflite
models/weights/*
!models/weights/.gitkeep

# Cache
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Jupyter
.ipynb_checkpoints/

# Temporary
tmp/
temp/
*.tmp
*.temp

# Docker
docker-compose.override.yml

# PDFs gerados (manter apenas os de referência)
data/exports/*.pdf
!docs/referencias/pdfs/*.pdf

# Exceções - manter estrutura de pastas
!data/.gitkeep
!data/sessoes/.gitkeep
!data/exports/.gitkeep
!models/.gitkeep
